# Required: token that protects GET /code and POST /code/clear.
# Generate with: openssl rand -hex 32
API_TOKEN=

# How long a captured code stays valid, in seconds (default 600 = 10 minutes).
CODE_TTL_SECONDS=600

# Optional: HTTP Basic Auth for the Postmark inbound webhook.
# If both are set, Postmark must call the webhook with these credentials
# (embed them in the URL: https://USER:PASS@your-host/webhook/inbound).
# Leave blank to leave the webhook unauthenticated.
WEBHOOK_USERNAME=
WEBHOOK_PASSWORD=
